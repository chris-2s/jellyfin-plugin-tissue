{
    // Paths, plugin name, and target frameworks are configured in settings.json.
    "version": "0.2.0",
    "configurations": [
        {
            "type": "coreclr",
            "name": "Launch Jellyfin (Tissue Debug)",
            "request": "launch",
            "preLaunchTask": "build-and-copy",
            "program": "${config:jellyfinDir}/bin/Debug/${config:jellyfinTargetFramework}/jellyfin.dll",
            "args": [
               //"--nowebclient"
               "--webdir",
               "${config:jellyfinWebDir}/"
            ],
            "cwd": "${config:jellyfinDir}"
        }
    ]
}
